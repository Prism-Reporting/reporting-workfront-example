WF_API_KEY=
WF_BASE_URL=

# Optional: comma-separated DE: custom field names to include in tasks query (e.g. DE:CustomText,DE:CustomNumber).
# If unset, all custom form (parameterValues) fields are included in task rows under customFields.
# WF_TASK_CUSTOM_FIELDS=

# Optional: for the server-side dashboard-building agent.
# The agent uses OpenAI plus the reporting MCP server.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional override if the reporting MCP server is built elsewhere.
# Defaults to ../reporting/packages/mcp-server/dist/index.js
REPORTING_MCP_SERVER_PATH=
